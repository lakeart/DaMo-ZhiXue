# 讯飞智文 PPT（zwapi.xfyun.cn）
# 复制为 .env 后填入自己的密钥（不要提交 .env）
XFYUN_ZW_APP_ID=你的APP_ID
XFYUN_ZW_API_SECRET=你的API_SECRET

# OpenAI 兼容大模型配置（用于知识库 RAG 回答生成、画像/资源等模块）
# 如接入 OpenAI / DeepSeek / Moonshot / 智谱兼容网关，可填写以下项
OPENAI_API_KEY=你的API_KEY
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# 本地 Ollama 可选配置
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# 知识库检索后端
# auto: 优先使用 ChromaDB，失败时回退 TF-IDF
# tfidf: 强制使用当前轻量检索
# chroma: 强制使用 ChromaDB，初始化失败时自动回退 TF-IDF
# KNOWLEDGE_RETRIEVAL_BACKEND=auto
# CHROMA_DB_PATH=instance/chroma/knowledge

# 可选：自定义接口域名（一般不需要改）
# XFYUN_ZW_BASE_URL=https://zwapi.xfyun.cn

# 讯飞 Spark 文生图（TTI，用于思维导图）
# 请求地址：https://spark-api.cn-huabei-1.xf-yun.com/v2.1/tti
XFYUN_TTI_APP_ID=你的APP_ID
XFYUN_TTI_API_KEY=你的API_KEY
XFYUN_TTI_API_SECRET=你的API_SECRET
# 可选：自定义域名（一般不需要改）
# XFYUN_TTI_BASE_URL=https://spark-api.cn-huabei-1.xf-yun.com

# 讯飞数字人教学视频（VMS）
# 默认请求地址示例（以你实际开通的服务为准）：
#   https://vms.cn-huadong-1.xf-yun.com/v1/private/video/generate
#   https://vms.cn-huadong-1.xf-yun.com/v1/private/video/query
# 鉴权：将 authorization/date/host 追加到 URL Query（后端已实现）
XFYUN_DH_APP_ID=你的APP_ID
XFYUN_DH_API_KEY=你的API_KEY
XFYUN_DH_API_SECRET=你的API_SECRET
# 可选：自定义域名/路径（如你的文档为 /api/v1 前缀，可在此覆盖）
# XFYUN_DH_BASE_URL=https://vms.cn-huadong-1.xf-yun.com
# XFYUN_DH_GENERATE_PATH=/v1/private/video/generate
# XFYUN_DH_QUERY_PATH=/v1/private/video/query
